# AlgoBrainDoctor Production Environment Variables
# 
# This file contains placeholder values for production deployment.
# When deploying to Vercel, set these values in the Vercel dashboard.
#
# ⚠️ IMPORTANT: Never commit actual secrets to version control!

# ============================================
# API Configuration
# ============================================

# Base URL for the API (when backend is implemented)
VITE_API_BASE_URL=https://api.algobraindoctor.io
VITE_API_VERSION=v1

# ============================================
# GitHub Integration
# ============================================

# GitHub OAuth App credentials (obtain from GitHub Developer Settings)
VITE_GITHUB_CLIENT_ID=your_github_client_id_here
VITE_GITHUB_REDIRECT_URI=https://your-domain.vercel.app/auth/callback

# GitHub Personal Access Token (for API calls)
# Scopes needed: repo, read:user
VITE_GITHUB_TOKEN=ghp_your_github_token_here

# ============================================
# Feature Flags
# ============================================

# Enable/disable features
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_WEBHOOKS=false
VITE_ENABLE_REAL_REPOS=true
VITE_ENABLE_AI_CHAT=true

# ============================================
# Performance & Caching
# ============================================

# Cache TTL in milliseconds (5 minutes default)
VITE_CACHE_TTL=300000

# Maximum repositories to monitor
VITE_MAX_REPOSITORIES=1000

# Worker refresh interval in milliseconds (30 seconds)
VITE_WORKER_REFRESH_INTERVAL=30000

# ============================================
# External Services (Future)
# ============================================

# Sentry for error tracking
VITE_SENTRY_DSN=your_sentry_dsn_here

# Analytics (Google Analytics, PostHog, etc.)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_POSTHOG_API_KEY=your_posthog_key_here

# ============================================
# Application Configuration
# ============================================

# Application environment
VITE_APP_ENV=production

# Application URL
VITE_APP_URL=https://your-domain.vercel.app

# API rate limits (requests per hour)
VITE_RATE_LIMIT_FREE=100
VITE_RATE_LIMIT_PRO=5000

# ============================================
# Vercel-Specific Variables
# ============================================
# These are automatically set by Vercel, no need to configure:
# - VERCEL_URL
# - VERCEL_ENV (production, preview, development)
# - VERCEL_GIT_COMMIT_SHA
# - VERCEL_GIT_COMMIT_MESSAGE

# ============================================
# NOTES FOR DEPLOYMENT
# ============================================
#
# 1. In Vercel Dashboard:
#    - Go to Project Settings > Environment Variables
#    - Add each VITE_* variable with actual values
#    - Select "Production" environment
#
# 2. GitHub Token Scopes:
#    - repo (full access to repositories)
#    - read:user (read user profile data)
#
# 3. GitHub OAuth Setup:
#    - Create OAuth App at https://github.com/settings/developers
#    - Set Authorization callback URL to your Vercel domain
#    - Copy Client ID and generate Client Secret
#
# 4. Recommended Security:
#    - Rotate tokens regularly
#    - Use different tokens for different environments
#    - Enable GitHub token expiration
#    - Use Vercel's encrypted environment variables
#
# 5. Testing Configuration:
#    - Test with preview deployments first
#    - Verify all integrations work
#    - Check browser console for config errors
