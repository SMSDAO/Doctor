# AlgoBrainDoctor Development Environment Variables
# 
# Copy this file to .env.local for local development
#
# Note: .env.local is gitignored and will not be committed

# ============================================
# Development Configuration
# ============================================

VITE_APP_ENV=development
VITE_APP_URL=http://localhost:5173

# ============================================
# GitHub Integration (Development)
# ============================================

# For local development, you can use a personal access token
VITE_GITHUB_TOKEN=

# OAuth settings for development
VITE_GITHUB_CLIENT_ID=
VITE_GITHUB_REDIRECT_URI=http://localhost:5173/auth/callback

# ============================================
# Feature Flags (Development)
# ============================================

VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_WEBHOOKS=false
VITE_ENABLE_REAL_REPOS=false
VITE_ENABLE_AI_CHAT=true

# ============================================
# Performance (Development)
# ============================================

VITE_CACHE_TTL=60000
VITE_MAX_REPOSITORIES=100
VITE_WORKER_REFRESH_INTERVAL=30000

# ============================================
# External Services (Development)
# ============================================

# Leave empty for development
VITE_SENTRY_DSN=
VITE_GA_MEASUREMENT_ID=
VITE_POSTHOG_API_KEY=
